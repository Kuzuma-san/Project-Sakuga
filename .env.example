# ─────────────────────────────────────────────────────────────────────────────
# Sakuga — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# .env is in .gitignore and MUST NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────
# ── ENVIRONMENT ───────────────────────────────────────────────────────────────
NODE_ENV=development # development | test | production
# ── POSTGRESQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=sakuga_user
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD
POSTGRES_DB=sakuga_db
POSTGRES_PORT=5432
# Used by Prisma (backend only — runs on host machine)
DATABASE_URL=postgresql://sakuga_user:CHANGE_ME@localhost:5432/sakuga_db
# Used by NestJS inside Docker network
DATABASE_URL_INTERNAL=postgresql://sakuga_user:CHANGE_ME@postgres:5432/sakuga_db
# ── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_PORT=6379
# Used by NestJS inside Docker network
REDIS_URL=redis://:CHANGE_ME@redis:6379
# ── KAFKA ─────────────────────────────────────────────────────────────────────
KAFKA_PORT=9092
# Used by NestJS inside Docker network
KAFKA_BROKERS=kafka:29092
# ── PGADMIN ───────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD
PGADMIN_PORT=5050
# ── BACKEND ───────────────────────────────────────────────────────────────────
BACKEND_PORT=3000
FRONTEND_URL=http://localhost:5173
# JWT — Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARS_CRYPTOGRAPHICALLY_RANDOM
JWT_EXPIRY=15m
REFRESH_TOKEN_SECRET=CHANGE_ME_DIFFERENT_FROM_JWT_SECRET
REFRESH_TOKEN_EXPIRY=7d
CSRF_SECRET=CHANGE_ME_CSRF_SIGNING_SECRET
# Email verification + password reset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@sakuga.app
# ── GOOGLE OAUTH ──────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
# ── ANTHROPIC (Claude API) ────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
# ── ENCRYPTION ────────────────────────────────────────────────────────────────
# For encrypting sensitive data at rest (e.g., OAuth tokens)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_EXACTLY_64_HEX_CHARS
# ── FRONTEND ──────────────────────────────────────────────────────────────────
# Vite only exposes VITE_ prefixed variables to the browser.
# Never put secrets here — they are bundled into the client JS.
VITE_API_URL=http://localhost:3000
VITE_APP_NAME=Sakuga
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com